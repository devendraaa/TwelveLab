{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "^(?!/api)(.*)",
      "dest": "frontend/$1"
    }
  ]
}