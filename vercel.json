{ 
  "builds": 
  [ { "src": "api/index.py", 
      "use": "@vercel/python" 
    }, 
    { "src": "frontend/package.json", 
      "use": "@vercel/next"  
    } 
  ], 
  "routes": 
  [ { "src": "/(synthesize|voices|health)", 
      "dest": "api/index.py" 
    }, 
    { "src": "/(.*)", 
      "dest": "frontend/$1" 
    } 
  ] }